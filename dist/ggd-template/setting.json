{
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "Write|Edit",
          "hooks": [
            {
              "type": "command",
              "command": "python .claude/hooks/enforce_ggd.py"
            }
          ]
        },
        {
          "matcher": "Read",
          "hooks": [
            {
              "type": "command",
              "command": "python .claude/hooks/enforce_ggd.py"
            }
          ]
        }
      ]
    }
  }
